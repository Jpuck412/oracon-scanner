# Required
FMPKEY=your_fmp_key_here
TRADIER_API_KEY=your_actual_tradier_access_token_here

# Use "live" for production token.
# Use "sandbox" for paper/sandbox token.
TRADIER_ENV=sandbox

# Optional override.
# For sandbox:
# TRADIER_BASE_URL=https://sandbox.tradier.com/v1
# For live:
# TRADIER_BASE_URL=https://api.tradier.com/v1

# Required fallback when FMP biggest-gainers is restricted.
# Put your penny-stock universe here.
SCANNER_SYMBOLS=HOLO,PEGY,SOUN,BBAI,MLGO,NAAS,OPTT,MAXN,TRNR,PRZO

# Optional. If FMP float endpoint is blocked, this lets Rubicon still operate.
# Set to 0 if you want unknown-float stocks to stay YELLOW.
UNKNOWN_FLOAT_SHARES=15000000
